NODE_ENV=development
PORT=5000

# Required for JWT auth
JWT_SECRET=replace-with-a-long-random-secret

# Frontend/base URL used in verification links
APP_BASE_URL=http://localhost:5000

# CORS origin(s): use "*" for all (dev) or comma-separated list in production
# Example:
# CORS_ORIGIN=https://your-frontend.com,https://admin.your-frontend.com
CORS_ORIGIN=*

# Optional SMTP config (if not set, Ethereal test inbox is used)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@myuniversity.edu

# Optional Supabase config (required for GET /teachers route)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key

