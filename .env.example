# ============================================================
# UNIPROF – Backend Environment Variables
# Copy this file to .env and fill in all values.
# DO NOT commit .env to version control.
# ============================================================

# Runtime mode
NODE_ENV=development

# Server port (default: 5000)
PORT=5000

# ----------------------------------------------------------
# Authentication
# Generate a strong random value, e.g.: openssl rand -hex 64
# ----------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret

# ----------------------------------------------------------
# Supabase (ALL FOUR are required)
# ----------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# Wildcards (*) are NOT supported – list each origin explicitly.
# Example (production):
#   CORS_ORIGIN=https://uniprof.vercel.app,https://admin.uniprof.vercel.app
# Example (local dev):
#   CORS_ORIGIN=http://localhost:5173
# ----------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ----------------------------------------------------------
# Rate Limiting (optional – defaults shown)
# ----------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=25
