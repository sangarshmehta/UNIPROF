# ===========================
# Dependencies
# ===========================
node_modules/
backend/node_modules/
frontend/node_modules/

# ===========================
# Environment files
# Keep .env.example tracked; ignore everything else.
# ===========================
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.staging
!.env.example
!backend/.env.example
!frontend/.env.example

# ===========================
# Build / cache artefacts
# ===========================
dist/
build/
frontend/build/
frontend/dist/
frontend/.vite/
.vite/

# ===========================
# Logs
# ===========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
