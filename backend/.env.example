NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=25

# Comma-separated allowed origins.
# Development: use * to allow all, or a specific localhost port.
# Production: list all allowed frontend origins, no spaces around commas.
# Vercel preview URLs (*.vercel.app) are always auto-allowed.
# Examples:
#   CORS_ORIGIN=*
#   CORS_ORIGIN=http://localhost:5173
#   CORS_ORIGIN=https://uniprof.vercel.app,https://uniprof-staging.vercel.app
CORS_ORIGIN=http://localhost:5173
